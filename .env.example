# Copy to ".env" in this directory (gitignored). godotenv loads it on startup.
# Values here do not override variables already exported in your shell.
#
# One-command setup (generates TIAMAT_HUB_TOKEN; does not overwrite an existing .env):
#   make init-env

# Public origin of Tiamat (scheme + host + port, no trailing slash).
# "localhost" is rewritten to 127.0.0.1 internally (avoids [::1] connection refused when Tiamat binds IPv4 only).
TIAMAT_BASE_URL=http://localhost:8080

# Must match Tiamat's TIAMAT_HUB_TOKEN exactly (same string on both processes).
TIAMAT_HUB_TOKEN=

# Sauron bind address (use a different port than Tiamat if both run locally).
SAURON_LISTEN=:8081

# --- Same-host cold start (optional; pick script OR systemd, not both) ---
# When /healthz is down, Sauron can run one of these from the OS user that runs Sauron.
# Anyone who can reach Sauron can trigger start — bind to loopback or add auth in prod.
#
# SAURON_TIAMAT_START_SCRIPT=/absolute/path/to/start-tiamat.sh   # executable (+x)
# SAURON_TIAMAT_STOP_SCRIPT=/absolute/path/to/stop-tiamat.sh     # executable (+x); if unset and start uses systemd, uses systemctl stop
# SAURON_TIAMAT_SYSTEMD_UNIT=tiamat.service
# SAURON_SYSTEMD_USER=1   # use systemctl --user (omit for system units)

# --- Tiamat (media_server) ---
# On the Tiamat host, set the same hub token so /api/hub/v1/* accepts Bearer auth:
#   TIAMAT_HUB_TOKEN=<same value as above>
# If TIAMAT_HUB_TOKEN is unset on Tiamat, hub routes return 503 (hub API disabled).
